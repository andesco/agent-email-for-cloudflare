{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "agent-email-for-cloudflare",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "r2_buckets": [
    {
      "binding": "INBOX"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB"
    }
  ],
  "triggers": {
    "crons": ["* * * * *"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
